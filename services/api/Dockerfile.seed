FROM node:20-alpine
WORKDIR /app
# Copy monorepo base tsconfig (build context = monorepo root)
COPY tsconfig.base.json /tsconfig.base.json
# Copy service files
COPY services/api/package*.json ./
COPY services/api/prisma ./prisma/
COPY services/api/tsconfig.json ./
RUN npm install
RUN npx prisma generate
COPY services/api/ .
CMD ["sh", "-c", "npx prisma migrate deploy && npx ts-node --project tsconfig.json prisma/seed.ts"]
